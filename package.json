{
  "name": "gamebanana-api-docs",
  "version": "0.2.0",
  "private": true,
  "description": "Unofficial GameBanana API docs powered by Docusaurus.",
  "scripts": {
    "postinstall": "node scripts/copy-rapidoc.mjs",
    "start": "node --require ./scripts/noop-webpackbar.cjs ./node_modules/@docusaurus/core/bin/docusaurus.mjs start --host 0.0.0.0 --port 3000",
    "build": "node --require ./scripts/noop-webpackbar.cjs ./node_modules/@docusaurus/core/bin/docusaurus.mjs build",
    "serve": "node --require ./scripts/noop-webpackbar.cjs ./node_modules/@docusaurus/core/bin/docusaurus.mjs serve build --host 0.0.0.0 --port 3000",
    "clear": "node --require ./scripts/noop-webpackbar.cjs ./node_modules/@docusaurus/core/bin/docusaurus.mjs clear",
    "deploy": "node --require ./scripts/noop-webpackbar.cjs ./node_modules/@docusaurus/core/bin/docusaurus.mjs deploy"
  },
  "dependencies": {
    "@docusaurus/core": "3.8.1",
    "@docusaurus/preset-classic": "3.8.1",
    "prism-react-renderer": "^2.4.1",
    "rapidoc": "9.3.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=18"
  }
}
